{
  "name": "app",
  "private": true,
  "type": "module",
  "imports": {
    "#/*": "./src/*"
  },
  "scripts": {
    "build": "vite build",
    "build:cloudflare": "CEIRD_CLOUDFLARE=1 vite build",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "dev": "vite dev --host 127.0.0.1 --port 4173 --strictPort",
    "e2e": "playwright test --project=chromium",
    "perf:jobs-workspace": "tsx src/features/jobs-workspace/jobs-workspace-performance-harness.ts",
    "perf:jobs-workspace:stage": "JOBS_WORKSPACE_STAGE_PERF_REQUIRED=1 playwright test e2e/jobs-workspace-performance.test.ts --project=chromium",
    "perf:sites-workspace": "tsx src/features/sites-workspace/sites-workspace-performance-harness.ts",
    "preview": "vite preview",
    "react-doctor": "react-doctor --diff false --blocking error --offline",
    "react-doctor:staged": "react-doctor --staged --no-dead-code --blocking error --offline",
    "test": "vitest run",
    "test:browser": "vitest run --project app-browser-chromium",
    "test:node": "vitest run --project app-node"
  },
  "dependencies": {
    "@ai-sdk/react": "3.0.204",
    "@base-ui/react": "^1.5.0",
    "@better-auth/oauth-provider": "1.6.16",
    "@ceird/activity-core": "workspace:*",
    "@ceird/agents-core": "workspace:*",
    "@ceird/domain-core": "workspace:*",
    "@ceird/identity-core": "workspace:*",
    "@ceird/jobs-core": "workspace:^",
    "@ceird/labels-core": "workspace:*",
    "@ceird/proximity-core": "workspace:*",
    "@ceird/sites-core": "workspace:*",
    "@cloudflare/ai-chat": "0.8.5",
    "@electric-sql/client": "1.5.21",
    "@fontsource-variable/geist": "^5.2.9",
    "@fontsource-variable/raleway": "^5.2.8",
    "@hugeicons/core-free-icons": "^4.2.0",
    "@hugeicons/react": "^1.1.6",
    "@standard-schema/spec": "1.1.0",
    "@tailwindcss/vite": "^4.3.0",
    "@tanstack/electric-db-collection": "0.3.6",
    "@tanstack/query-core": "5.101.0",
    "@tanstack/query-db-collection": "1.0.40",
    "@tanstack/react-db": "0.1.86",
    "@tanstack/react-devtools": "0.10.5",
    "@tanstack/react-form": "^1.33.0",
    "@tanstack/react-hotkeys": "^0.10.0",
    "@tanstack/react-query": "5.101.0",
    "@tanstack/react-router": "1.170.15",
    "@tanstack/react-router-devtools": "1.167.0",
    "@tanstack/react-router-ssr-query": "1.167.1",
    "@tanstack/react-start": "1.168.25",
    "@tanstack/router-plugin": "1.168.18",
    "agents": "0.16.0",
    "ai": "6.0.202",
    "better-auth": "1.6.16",
    "class-variance-authority": "^0.7.1",
    "clsx": "^2.1.1",
    "cmdk": "^1.1.1",
    "effect": "4.0.0-beta.79",
    "input-otp": "^1.4.2",
    "lucide-react": "^1.17.0",
    "maplibre-gl": "^6.0.0-14",
    "react": "^19.2.7",
    "react-dom": "^19.2.7",
    "react-qr-code": "^2.2.0",
    "shadcn": "^4.11.0",
    "sonner": "^2.0.7",
    "tailwind-merge": "^3.6.0",
    "tailwindcss": "^4.3.0",
    "tw-animate-css": "^1.4.0",
    "vaul": "^1.1.2",
    "zod": "4.4.3"
  },
  "devDependencies": {
    "@effect/language-service": "^0.86.2",
