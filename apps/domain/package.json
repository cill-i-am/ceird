{
  "name": "domain",
  "private": true,
  "type": "module",
  "scripts": {
    "build": "tsc -p tsconfig.json",
    "check-types": "tsc --noEmit -p tsconfig.json",
    "db:generate": "drizzle-kit generate --ignore-conflicts",
    "db:migrate": "drizzle-kit migrate --ignore-conflicts",
    "db:studio": "drizzle-kit studio",
    "dev": "tsx watch src/index.ts",
    "test": "vitest run --no-file-parallelism --maxWorkers=1"
  },
  "dependencies": {
    "@better-auth/oauth-provider": "1.6.16",
    "@ceird/agents-core": "workspace:*",
    "@ceird/comments-core": "workspace:*",
    "@ceird/domain-core": "workspace:*",
    "@ceird/identity-core": "workspace:*",
    "@ceird/jobs-core": "workspace:*",
    "@ceird/labels-core": "workspace:*",
    "@ceird/proximity-core": "workspace:*",
    "@ceird/sites-core": "workspace:*",
    "@ceird/worker-observability": "workspace:*",
    "@effect/platform-node": "4.0.0-beta.79",
    "@effect/sql-pg": "4.0.0-beta.79",
    "better-auth": "1.6.16",
    "drizzle-orm": "1.0.0-rc.3-e9dfa4b",
    "effect": "4.0.0-beta.79",
    "ioredis": "^5.11.1",
    "pg": "8.21.0",
    "uuid": "14.0.0"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@effect/language-service": "^0.86.2",
    "@effect/vitest": "4.0.0-beta.79",
    "@types/node": "^25.9.3",
    "@types/pg": "8.20.0",
    "drizzle-kit": "1.0.0-rc.4-ca0f029",
    "tsx": "^4.22.4",
    "vite": "^8.0.16",
    "vitest": "4.1.8"
  }
}
