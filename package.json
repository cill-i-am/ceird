{
  "name": "ceird",
  "private": true,
  "type": "module",
  "scripts": {
    "alchemy": "alchemy",
    "alchemy:doctor": "node scripts/alchemy-doctor.mjs",
    "alchemy:state-audit": "node scripts/alchemy-state-audit.mjs",
    "build": "pnpm -r --if-present build",
    "check": "ultracite check .",
    "check-types": "pnpm -r --if-present check-types && pnpm run check-types:infra",
    "check-types:infra": "tsc --noEmit -p tsconfig.infra.json",
    "dev": "node scripts/alchemy-dev.mjs",
    "eval:skills": "node scripts/run-skill-evals.mjs",
    "eval:skills:forward": "node scripts/run-skill-evals.mjs --forward-prompts",
    "fix": "ultracite fix .",
    "format": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "knip": "knip --no-config-hints",
    "lint": "oxlint .",
    "opensrc:sync": "node scripts/sync-opensrc.mjs",
    "postinstall": "pnpm run opensrc:sync",
    "prebuild": "pnpm run opensrc:sync",
    "prepare": "node scripts/prepare.mjs",
    "test": "pnpm -r --if-present --workspace-concurrency=1 test && pnpm run test:infra && pnpm run test:scripts",
    "test:domain:integration": "node scripts/run-domain-integration-tests.mjs",
    "test:infra": "vitest run --dir infra --exclude 'opensrc/**'",
    "test:scripts": "node --test scripts/*.test.mjs",
    "topology:check": "node scripts/check-instruction-topology.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260611.1",
    "@effect/language-service": "^0.86.2",
    "@effect/platform-bun": "4.0.0-beta.79",
    "@effect/platform-node": "4.0.0-beta.79",
    "@effect/vitest": "4.0.0-beta.79",
    "@types/bun": "^1.3.14",
    "@types/node": "^25.9.3",
    "@types/picomatch": "^4.0.3",
    "alchemy": "2.0.0-beta.55",
    "drizzle-kit": "^1.0.0-rc.4-ca0f029",
    "drizzle-orm": "^1.0.0-rc.3-e9dfa4b",
    "effect": "4.0.0-beta.79",
    "ioredis": "^5.11.1",
    "knip": "6.16.1",
    "lefthook": "^2.1.9",
    "opensrc": "^0.7.2",
    "oxfmt": "^0.54.0",
    "oxlint": "^1.69.0",
    "portless": "^0.14.0",
    "tsx": "^4.22.4",
    "typescript": "6.0.3",
    "ultracite": "^7.8.3",
    "vite": "^8.0.16",
    "vitest": "^4.1.8",
    "workerd": "1.20260611.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.61.1"
  },
  "engines": {
    "node": ">=24"
  },
  "packageManager": "pnpm@10.34.3"
}
