{
  "name": "ceird",
  "private": true,
  "type": "module",
  "scripts": {
    "alchemy": "alchemy",
    "build": "pnpm -r --if-present build",
    "check": "ultracite check .",
    "check-types": "pnpm -r --if-present check-types && pnpm run check-types:infra",
    "check-types:infra": "tsc --noEmit -p tsconfig.infra.json",
    "dev": "node scripts/alchemy-dev.mjs",
    "fix": "ultracite fix .",
    "format": "oxfmt --check .",
    "format:write": "oxfmt --write .",
    "knip": "knip --no-config-hints",
    "lint": "oxlint --config .oxlintrc.mjs . --ignore-pattern '.agents/**' --ignore-pattern 'opensrc/**' --ignore-pattern 'apps/app/src/routeTree.gen.ts'",
    "opensrc:sync": "node scripts/sync-opensrc.mjs",
    "postinstall": "pnpm run opensrc:sync",
    "prebuild": "pnpm run opensrc:sync",
    "prepare": "node scripts/prepare.mjs",
    "test": "pnpm -r --if-present --workspace-concurrency=1 test && pnpm run test:infra && pnpm run test:scripts",
    "test:domain:integration": "node scripts/run-domain-integration-tests.mjs",
    "test:infra": "vitest run --dir infra --exclude 'opensrc/**'",
    "test:scripts": "node --test scripts/*.test.mjs"
  },
  "devDependencies": {
    "@cloudflare/workers-types": "^4.20260501.1",
    "@effect/language-service": "^0.84.3",
    "@effect/platform-bun": "4.0.0-beta.68",
    "@effect/platform-node": "4.0.0-beta.68",
    "@effect/vitest": "4.0.0-beta.68",
    "@types/bun": "^1.3.13",
    "@types/node": "^25.6.0",
    "@types/picomatch": "^4.0.3",
    "alchemy": "2.0.0-beta.44",
    "drizzle-kit": "^1.0.0-rc.1",
    "drizzle-orm": "^1.0.0-rc.1",
    "effect": "4.0.0-beta.68",
    "knip": "6.12.1",
    "lefthook": "^2.1.6",
    "opensrc": "^0.6.0",
    "oxfmt": "^0.43.0",
    "oxlint": "^1.62.0",
    "tsx": "^4.21.0",
    "typescript": "5.9.2",
    "ultracite": "^7.6.2",
    "vite": "^8.0.10",
    "vitest": "^3.2.4",
    "workerd": "1.20260528.1"
  },
  "optionalDependencies": {
    "@rollup/rollup-linux-x64-gnu": "4.60.1"
  },
  "engines": {
    "node": ">=22"
  },
  "packageManager": "pnpm@9.15.9",
  "pnpm": {
    "onlyBuiltDependencies": [
      "esbuild",
      "lefthook",
      "lightningcss"
    ],
    "packageExtensions": {
      "drizzle-kit@>=1.0.0-rc.1": {
        "dependencies": {
          "drizzle-orm": "^1.0.0-rc.1"
        }
      }
    },
    "supportedArchitectures": {
      "cpu": [
        "current",
        "x64"
      ],
      "libc": [
        "current",
        "glibc"
      ],
      "os": [
        "current",
        "linux"
      ]
    },
    "patchedDependencies": {
      "ajv@8.20.0": "patches/ajv@8.20.0.patch",
      "ajv-formats@3.0.1": "patches/ajv-formats@3.0.1.patch",
      "agents@0.13.2": "patches/agents@0.13.2.patch",
      "workers-ai-provider@3.1.14": "patches/workers-ai-provider@3.1.14.patch"
    }
  }
}
