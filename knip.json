{
  "$schema": "https://unpkg.com/knip@6/schema.json",
  "playwright": false,
  "include": [
    "dependencies",
    "devDependencies",
    "optionalPeerDependencies",
    "unlisted",
    "binaries",
    "unresolved",
    "catalog"
  ],
  "ignoreDependencies": [
    "@effect/platform-node",
    "@effect/vitest",
    "@fontsource-variable/raleway",
    "@tanstack/router-plugin",
    "@types/picomatch",
    "ajv",
    "ajv-formats",
    "cloudflare",
    "eslint",
    "opensrc",
    "portless",
    "tsx",
    "vite",
    "workerd"
  ],
  "ignoreBinaries": ["tar"]
}
